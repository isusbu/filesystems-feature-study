[global]
ioengine=sync
direct=0
runtime=20
time_based=1
group_reporting=1
thread=1
numjobs=4
size=2G
filesize=64k
unlink=1
create_on_open=1
invalidate=1
bsrange=4k-1M
openfiles=32
file_service_type=random

[randwrite_small]
rw=randwrite
bs=4k
iodepth=1
fsync=100

[randread_small]
rw=randread
bs=4k
iodepth=1
